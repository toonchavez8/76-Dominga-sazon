---
/* biome-ignore lint/correctness/noUnusedVariables: Astro frontmatter variable is used in template markup. */
const mapsUrl = "https://maps.app.goo.gl/HSoDPpuf5S4Gw3Bs9";
---

<footer
    class="pb-10 pt-16"
    style="background: var(--color-dominia-dark-brown);"
>
    <div class="mx-auto max-w-6xl px-6">
        <div
            class="flex flex-wrap justify-between"
            style="border-color: rgba(255,255,255,0.08); background: linear-gradient(135deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));"
        >
            <div>
                <a
                    href="#inicio"
                    class="block text-2xl font-semibold leading-tight"
                    style="font-family: var(--font-heading); color: var(--color-dominia-gold);"
                >
                    Dominga y su Sazón
                </a>
                <p class="mt-4 max-w-md text-sm leading-7">
                    Cocina casera salvadoreña y mexicana en El Fortín,
                    Guadalajara. <br /> Pupusas, barbacoa y antojitos preparados al
                    momento cada fin de semana.
                </p>
            </div>

            <div>
                <div class="space-y-3 text-sm">
                    <a
                        href="https://wa.me/5213322626550"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center rounded-full px-4 py-2 text-sm font-semibold"
                        style="background: var(--color-dominia-terracotta); color: white;"
                    >
                        Pedir por WhatsApp
                    </a>
                    <div
                        class="sr-only"
                        aria-hidden="true"
                        data-social-links="hidden"
                    >
                        Enlaces sociales reservados para una publicación futura.
                    </div>
                </div>
            </div>
        </div>

        <div
            class="mt-6 flex flex-col gap-3 text-xs sm:flex-row sm:items-center sm:justify-between"
        >
            <p style="color: rgba(255, 255, 255, 0.36);">
                &copy; <span id="current-year"></span> Dominga y su Sazón. Todos los
                derechos reservados.
            </p>
            <a
                href="#inicio"
                class="inline-flex items-center text-xs font-semibold"
                style="color: rgba(255, 255, 255, 0.56);"
            >
                Volver arriba
            </a>
        </div>
    </div>
</footer>

<script>
    document.getElementById("current-year")!.textContent = new Date()
        .getFullYear()
        .toString();
</script>
