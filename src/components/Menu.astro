---
/* biome-ignore lint/correctness/noUnusedImports: Astro frontmatter import is used in template markup. */
import menuData from "../data/menu.json";
/* biome-ignore lint/correctness/noUnusedImports: Astro frontmatter import is used in template markup. */
import MenuSection from "./MenuSection";
---

<section
    id="menu"
    class="py-24 sm:py-32"
    style="background: var(--color-dominia-warm-white);"
>
    <div class="mx-auto max-w-4xl px-6">
        <div class="mb-12 text-center sm:mb-16">
            <h2 class="mb-4">Nuestro menú</h2>
            <p class="mx-auto max-w-md text-base text-balance text-dominia-slate">
                Todos los platillos se preparan al momento. Precios por pieza.
            </p>
        </div>

        <MenuSection client:load menuData={menuData} />
    </div>
</section>
