---
/* biome-ignore lint/correctness/noUnusedVariables: Astro frontmatter variable is used in template markup. */
const mapsUrl = "https://maps.app.goo.gl/HSoDPpuf5S4Gw3Bs9";
---

<section
    id="contacto"
    class="py-24 sm:py-32"
    style="background: var(--color-dominia-paper);"
>
    <div class="mx-auto max-w-6xl px-6">
        <div class="mb-12 text-center sm:mb-16">
            <h2 class="mb-4">Encuéntranos</h2>
            <p class="mx-auto max-w-md text-base text-balance text-dominia-slate">
                Sábados y domingos, de 11:00 a 16:00. Te esperamos.
            </p>
        </div>

        <div class="mb-16 grid gap-4 sm:grid-cols-3">
            <a
                data-contact-link="phone"
                class="group flex flex-col items-center rounded-xl p-5 text-center transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0 sm:items-start sm:text-left"
                style="background: var(--color-dominia-warm-white); border: 1px solid var(--color-dominia-border); box-shadow: 0 1px 2px rgba(26, 24, 20, 0.03);"
                aria-label="Llamar a Dominga y su Sazón"
            >
                <div
                    class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg"
                    style="background: var(--color-dominia-terracotta-light);"
                >
                    <svg
                        class="h-4.5 w-4.5"
                        style="color: var(--color-dominia-terracotta);"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
                        ></path>
                    </svg>
                </div>
                <h3
                    class="mb-1 text-sm font-semibold"
                    style="color: var(--color-dominia-ink);"
                >
                    Teléfono
                </h3>
                <p
                    class="text-xs leading-relaxed"
                    style="color: var(--color-dominia-slate);"
                >
                    Toca para llamarnos directamente.
                </p>
            </a>

            <a
                href={mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col items-center rounded-xl p-5 text-center transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0 sm:items-start sm:text-left"
                style="background: var(--color-dominia-warm-white); border: 1px solid var(--color-dominia-border); box-shadow: 0 1px 2px rgba(26, 24, 20, 0.03);"
            >
                <div
                    class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg"
                    style="background: var(--color-dominia-gold-light);"
                >
                    <svg
                        class="h-4.5 w-4.5"
                        style="color: var(--color-dominia-gold);"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                        ></path>
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                        ></path>
                    </svg>
                </div>
                <h3
                    class="mb-1 text-sm font-semibold"
                    style="color: var(--color-dominia-ink);"
                >
                    Dirección
                </h3>
                <p
                    class="text-xs leading-relaxed"
                    style="color: var(--color-dominia-slate);"
                >
                    El Fortín, Guadalajara
                </p>
            </a>

            <div
                class="flex flex-col items-center rounded-xl p-5 text-center sm:items-start sm:text-left"
                style="background: var(--color-dominia-warm-white); border: 1px solid var(--color-dominia-border); box-shadow: 0 1px 2px rgba(26, 24, 20, 0.03);"
            >
                <div
                    class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg"
                    style="background: rgba(212, 168, 83, 0.12);"
                >
                    <svg
                        class="h-4.5 w-4.5"
                        style="color: var(--color-dominia-gold);"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
                        ></path>
                    </svg>
                </div>
                <h3
                    class="mb-1 text-sm font-semibold"
                    style="color: var(--color-dominia-ink);"
                >
                    Horario
                </h3>
                <p
                    class="text-xs leading-relaxed"
                    style="color: var(--color-dominia-slate);"
                >
                    Sáb. y dom.<br />11:00 - 16:00
                </p>
            </div>
        </div>

        <div
            class="overflow-hidden rounded-2xl border"
            style="border-color: var(--color-dominia-border); box-shadow: 0 1px 3px rgba(26, 24, 20, 0.04);"
        >
            <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3734.028281824205!2d-103.47497472387792!3d20.62770400143089!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8428ab00433fa173%3A0xd9e2856a7b0cbf55!2sDominga%20y%20su%20Saz%C3%B3n!5e0!3m2!1sen!2smx!4v1782615519195!5m2!1sen!2smx"
                width="100%"
                height="100%"
                class="min-h-[360px]"
                style="border: 0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                sandbox="allow-scripts allow-same-origin allow-popups"
                title="Mapa de Dominga y su Sazón en El Fortín, Guadalajara, Jalisco"
            >
            </iframe>
        </div>
    </div>
</section>
